@model PensionatoApp.Models.Reserva
@{
    ViewData["Title"] = "Reserva Confirmada";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-success">
                <div class="card-header bg-success text-white text-center">
                    <h3 class="mb-0">
                        <i class="fas fa-check-circle"></i>
                        Reserva Confirmada!
                    </h3>
                </div>
                <div class="card-body">
                    <div class="alert alert-success text-center mb-4">
                        <h4><i class="fas fa-calendar-check"></i> Sua reserva foi recebida com sucesso!</h4>
                        <p class="mb-0">Nossa equipe entrará em contato em breve para finalizar os detalhes.</p>
                    </div>
                    
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <h5><i class="fas fa-door-open text-primary"></i> Detalhes da Suíte</h5>
                            <ul class="list-unstyled">
                                <li><strong>Suíte:</strong> @Model.Suite?.Numero</li>
                                <li><strong>Tipo de Cama:</strong> @Model.Suite?.TipoCama</li>
                                <li><strong>Preço Mensal:</strong> @Model.Suite?.PrecoMensal.ToString("C")</li>
                                @if (Model.TemArCondicionado)
                                {
                                    <li><strong>Ar Condicionado:</strong> +@Model.PrecoArCondicionado.ToString("C")</li>
                                }
                                @if (Model.TemGaragem)
                                {
                                    <li><strong>Garagem:</strong> +@Model.PrecoGaragem.ToString("C")</li>
                                }
                                <li class="mt-2"><strong>Valor Total Mensal:</strong> <span class="text-success">@Model.ValorMensalTotal.ToString("C")</span></li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <h5><i class="fas fa-calendar text-primary"></i> Período da Reserva</h5>
                            <ul class="list-unstyled">
                                <li><strong>Data de Entrada:</strong> @Model.DataEntrada.ToString("dd/MM/yyyy")</li>
                                <li><strong>Data de Saída:</strong> @Model.DataSaida.ToString("dd/MM/yyyy")</li>
                                <li><strong>Data da Reserva:</strong> @Model.DataReserva.ToString("dd/MM/yyyy")</li>
                                @if (Model.ValorCaucao > 0)
                                {
                                    <li><strong>Caução:</strong> @Model.ValorCaucao.ToString("C")</li>
                                }
                                @if (Model.ValorAdiantado > 0)
                                {
                                    <li><strong>Adiantamento:</strong> @Model.ValorAdiantado.ToString("C")</li>
                                }
                            </ul>
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-12">
                            <h5><i class="fas fa-user text-primary"></i> Dados do Hóspede</h5>
                            <ul class="list-unstyled">
                                <li><strong>Nome:</strong> @Model.Hospede?.NomeCompleto</li>
                                <li><strong>E-mail:</strong> @Model.Hospede?.Email</li>
                                <li><strong>Telefone:</strong> @Model.Hospede?.Telefone</li>
                                <li><strong>Documento:</strong> @Model.Hospede?.Documento</li>
                            </ul>
                        </div>
                    </div>
                    
                    <hr>
                    
                    <div class="alert alert-info">
                        <h6><i class="fas fa-info-circle"></i> Próximos Passos:</h6>
                        <ul class="mb-0">
                            <li>Nossa equipe entrará em contato através do telefone/e-mail informado</li>
                            <li>Confirmaremos os detalhes da reserva e valores</li>
                            <li>Orientaremos sobre a documentação necessária</li>
                            <li>Agendaremos a data de entrada</li>
                        </ul>
                    </div>
                    
                    <div class="d-grid gap-2 mt-4">
                        <a href="@Url.Action("Index")" class="btn btn-primary">
                            <i class="fas fa-home"></i> Voltar ao Início
                        </a>
                    </div>
                </div>
                <div class="card-footer text-center text-muted">
                    <small>
                        <i class="fas fa-phone"></i> Em caso de dúvidas, entre em contato: (11) 99999-9999
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>