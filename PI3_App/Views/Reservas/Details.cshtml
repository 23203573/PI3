@model PensionatoApp.Models.Reserva

@{
    ViewData["Title"] = "Detalhes da Reserva";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-md-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-controller="Suites" asp-action="Index">Suítes Ocupadas</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Detalhes da Reserva</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-12">
            <div class="d-flex justify-content-between align-items-center">
                <h2 class="text-primary">
                    <i class="fas fa-calendar-check me-2"></i>
                    Detalhes da Reserva #@Model.Id
                </h2>
                <div class="btn-group" role="group">
                    <a asp-controller="Suites" asp-action="Index" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left me-2"></i>Voltar às Ocupações
                    </a>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary">
                        <i class="fas fa-edit me-2"></i>Editar Reserva
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Informações Gerais -->
        <div class="col-lg-8 mb-4">
            <div class="card h-100">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-info-circle me-2"></i>
                        Informações da Reserva
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <h6 class="text-muted mb-2">
                                <i class="fas fa-door-open me-2"></i>Suíte
                            </h6>
                            <div class="d-flex align-items-center">
                                <span class="badge bg-primary fs-6 me-2">@Model.Suite?.Numero</span>
                                <span class="text-muted">@Model.Suite?.PrecoMensal.ToString("C") (base)</span>
                            </div>
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <h6 class="text-muted mb-2">
                                <i class="fas fa-calendar me-2"></i>Status da Reserva
                            </h6>
                            <span class="badge @(Model.Status == PensionatoApp.Models.StatusReserva.Ativa ? "bg-success" : Model.Status == PensionatoApp.Models.StatusReserva.Finalizada ? "bg-secondary" : "bg-danger") fs-6">
                                @Model.Status
                            </span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <h6 class="text-muted mb-2">
                                <i class="fas fa-calendar-plus me-2"></i>Data de Entrada
                            </h6>
                            <p class="mb-0">
                                <strong>@Model.DataEntrada.ToString("dd/MM/yyyy")</strong>
                                <small class="text-muted d-block">@Model.DataEntrada.ToString("dddd, MMMM dd, yyyy", new System.Globalization.CultureInfo("pt-BR"))</small>
                            </p>
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <h6 class="text-muted mb-2">
                                <i class="fas fa-calendar-minus me-2"></i>Data de Saída
                            </h6>
                            <p class="mb-0">
                                <strong>@Model.DataSaida.ToString("dd/MM/yyyy")</strong>
                                <small class="text-muted d-block">@Model.DataSaida.ToString("dddd, MMMM dd, yyyy", new System.Globalization.CultureInfo("pt-BR"))</small>
                            </p>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <h6 class="text-muted mb-2">
                                <i class="fas fa-clock me-2"></i>Duração da Estadia
                            </h6>
                            <p class="mb-0">
                                <strong>@((Model.DataSaida - Model.DataEntrada).Days) dias</strong>
                                @{
                                    var diasRestantes = (Model.DataSaida - DateTime.Now).Days;
                                }
                                @if (Model.Status == PensionatoApp.Models.StatusReserva.Ativa)
                                {
                                    @if (diasRestantes > 0)
                                    {
                                        <small class="text-info d-block">@diasRestantes dias restantes</small>
                                    }
                                    else if (diasRestantes == 0)
                                    {
                                        <small class="text-warning d-block"><i class="fas fa-exclamation-triangle"></i> Vence hoje!</small>
                                    }
                                    else
                                    {
                                        <small class="text-danger d-block"><i class="fas fa-times"></i> Vencida há @Math.Abs(diasRestantes) dias</small>
                                    }
                                }
                            </p>
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <h6 class="text-muted mb-2">
                                <i class="fas fa-calendar-alt me-2"></i>Data da Reserva
                            </h6>
                            <p class="mb-0">
                                <strong>@Model.DataReserva.ToString("dd/MM/yyyy HH:mm")</strong>
                                <small class="text-muted d-block">Origem: @Model.Origem</small>
                            </p>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Observacoes))
                    {
                        <div class="row">
                            <div class="col-12">
                                <h6 class="text-muted mb-2">
                                    <i class="fas fa-sticky-note me-2"></i>Observações
                                </h6>
                                <div class="alert alert-light">
                                    <p class="mb-0">@Model.Observacoes</p>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Informações Financeiras e Serviços -->
        <div class="col-lg-4">
            <!-- Valores -->
            <div class="card mb-4">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-dollar-sign me-2"></i>
                        Informações Financeiras
                    </h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <h6 class="text-muted mb-2">Valor Mensal Total</h6>
                        <h4 class="text-success mb-0">@Model.ValorMensalTotal.ToString("C")</h4>
                    </div>
                    
                    <hr>
                    
                    <div class="row">
                        <div class="col-6">
                            <h6 class="text-muted mb-2">Caução</h6>
                            <p class="mb-0"><strong>@Model.ValorCaucao.ToString("C")</strong></p>
                        </div>
                        <div class="col-6">
                            <h6 class="text-muted mb-2">Adiantado</h6>
                            <p class="mb-0"><strong>@Model.ValorAdiantado.ToString("C")</strong></p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Serviços Adicionais -->
            <div class="card mb-4">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-cogs me-2"></i>
                        Serviços Adicionais
                    </h5>
                </div>
                <div class="card-body">
                    <div class="list-group list-group-flush">
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <i class="fas fa-snowflake text-info me-2"></i>
                                Ar Condicionado
                            </div>
                            @if (Model.TemArCondicionado)
                            {
                                <div>
                                    <span class="badge bg-success rounded-pill">Sim</span>
                                    <small class="text-muted">+@Model.PrecoArCondicionado.ToString("C")</small>
                                </div>
                            }
                            else
                            {
                                <span class="badge bg-secondary rounded-pill">Não</span>
                            }
                        </div>
                        
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <i class="fas fa-car text-warning me-2"></i>
                                Garagem
                            </div>
                            @if (Model.TemGaragem)
                            {
                                <div>
                                    <span class="badge bg-success rounded-pill">Sim</span>
                                    <small class="text-muted">+@Model.PrecoGaragem.ToString("C")</small>
                                </div>
                            }
                            else
                            {
                                <span class="badge bg-secondary rounded-pill">Não</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Informações do Hóspede -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-user me-2"></i>
                        Informações do Hóspede
                    </h5>
                </div>
                <div class="card-body">
                    @if (Model.Hospede != null)
                    {
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <h6 class="text-muted mb-2">
                                    <i class="fas fa-id-card me-2"></i>Nome Completo
                                </h6>
                                <p class="mb-0">
                                    <strong>@Model.Hospede.NomeCompleto</strong>
                                </p>
                            </div>
                            
                            <div class="col-md-4 mb-3">
                                <h6 class="text-muted mb-2">
                                    <i class="fas fa-envelope me-2"></i>Email
                                </h6>
                                <p class="mb-0">
                                    @if (!string.IsNullOrEmpty(Model.Hospede.Email))
                                    {
                                        <a href="mailto:@Model.Hospede.Email" class="text-decoration-none">@Model.Hospede.Email</a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Não informado</span>
                                    }
                                </p>
                            </div>
                            
                            <div class="col-md-4 mb-3">
                                <h6 class="text-muted mb-2">
                                    <i class="fas fa-phone me-2"></i>Telefone
                                </h6>
                                <p class="mb-0">
                                    @if (!string.IsNullOrEmpty(Model.Hospede.Telefone))
                                    {
                                        <a href="tel:@Model.Hospede.Telefone" class="text-decoration-none">@Model.Hospede.Telefone</a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Não informado</span>
                                    }
                                </p>
                            </div>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <h6 class="text-muted mb-2">
                                    <i class="fas fa-file-alt me-2"></i>Documento
                                </h6>
                                <p class="mb-0">@Model.Hospede.Documento</p>
                            </div>
                            
                            <div class="col-md-4 mb-3">
                                <h6 class="text-muted mb-2">
                                    <i class="fas fa-birthday-cake me-2"></i>Data de Nascimento
                                </h6>
                                <p class="mb-0">
                                    @Model.Hospede.DataNascimento.ToString("dd/MM/yyyy")
                                    @{
                                        var idade = DateTime.Now.Year - Model.Hospede.DataNascimento.Year;
                                        if (DateTime.Now.DayOfYear < Model.Hospede.DataNascimento.DayOfYear) idade--;
                                    }
                                    <small class="text-muted">(@idade anos)</small>
                                </p>
                            </div>
                            
                            <div class="col-md-4 mb-3">
                                <h6 class="text-muted mb-2">
                                    <i class="fas fa-map-marker-alt me-2"></i>Endereço
                                </h6>
                                <p class="mb-0">
                                    @if (!string.IsNullOrEmpty(Model.Hospede.Endereco))
                                    {
                                        @Model.Hospede.Endereco
                                    }
                                    else
                                    {
                                        <span class="text-muted">Não informado</span>
                                    }
                                </p>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(Model.Hospede.ContatoEmergenciaNome))
                        {
                            <hr>
                            <h6 class="text-muted mb-3">
                                <i class="fas fa-exclamation-triangle me-2"></i>Contato de Emergência
                            </h6>
                            <div class="row">
                                <div class="col-md-6">
                                    <strong>Nome:</strong> @Model.Hospede.ContatoEmergenciaNome
                                </div>
                                <div class="col-md-6">
                                    <strong>Telefone:</strong> 
                                    @if (!string.IsNullOrEmpty(Model.Hospede.ContatoEmergenciaTelefone))
                                    {
                                        <a href="tel:@Model.Hospede.ContatoEmergenciaTelefone" class="text-decoration-none">@Model.Hospede.ContatoEmergenciaTelefone</a>
                                    }
                                </div>
                            </div>
                        }

                        <div class="mt-3">
                            <a asp-controller="Hospedes" asp-action="Details" asp-route-id="@Model.Hospede.Id" class="btn btn-outline-primary">
                                <i class="fas fa-user-circle me-2"></i>Ver Perfil Completo do Hóspede
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning">
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            Informações do hóspede não disponíveis.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Ações Adicionais -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="mb-0">
                        <i class="fas fa-tools me-2"></i>
                        Ações Disponíveis
                    </h5>
                </div>
                <div class="card-body">
                    <div class="btn-group" role="group">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                            <i class="fas fa-edit me-2"></i>Editar Reserva
                        </a>
                        <a asp-controller="Pagamentos" asp-action="Index" asp-route-reservaId="@Model.Id" class="btn btn-success">
                            <i class="fas fa-money-bill-wave me-2"></i>Ver Pagamentos
                        </a>
                        @if (Model.Status == PensionatoApp.Models.StatusReserva.Ativa)
                        {
                            <button type="button" class="btn btn-warning" data-bs-toggle="modal" data-bs-target="#finalizarReservaModal">
                                <i class="fas fa-check-circle me-2"></i>Finalizar Reserva
                            </button>
                        }
                        <a asp-controller="Reservas" asp-action="GerarContrato" asp-route-id="@Model.Id" class="btn btn-outline-secondary" target="_blank">
                            <i class="fas fa-file-contract me-2"></i>Gerar Contrato
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal para Finalizar Reserva -->
@if (Model.Status == PensionatoApp.Models.StatusReserva.Ativa)
{
    <div class="modal fade" id="finalizarReservaModal" tabindex="-1" aria-labelledby="finalizarReservaModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="finalizarReservaModalLabel">
                        <i class="fas fa-check-circle me-2"></i>Finalizar Reserva
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Tem certeza de que deseja finalizar esta reserva?</p>
                    <p><strong>Esta ação não pode ser desfeita.</strong></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <form asp-action="FinalizarReserva" method="post" class="d-inline">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-warning">
                            <i class="fas fa-check-circle me-2"></i>Finalizar Reserva
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}