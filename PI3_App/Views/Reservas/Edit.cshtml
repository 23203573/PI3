@model PensionatoApp.Models.Reserva

@{
    ViewData["Title"] = "Editar Reserva";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-md-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-controller="Suites" asp-action="Index">Suítes Ocupadas</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Editar Reserva</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-12">
            <div class="d-flex justify-content-between align-items-center">
                <h2 class="text-primary">
                    <i class="fas fa-edit me-2"></i>
                    Editar Reserva #@Model.Id
                </h2>
                <div class="btn-group" role="group">
                    <a asp-controller="Suites" asp-action="Index" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left me-2"></i>Voltar às Ocupações
                    </a>
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-info">
                        <i class="fas fa-eye me-2"></i>Ver Detalhes
                    </a>
                </div>
            </div>
        </div>
    </div>

    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="DataReserva" />

        <div class="row">
            <!-- Informações Básicas -->
            <div class="col-lg-8 mb-4">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-info-circle me-2"></i>
                            Informações da Reserva
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="SuiteId" class="form-label">
                                    <i class="fas fa-door-open me-2"></i>Suíte
                                </label>
                                <select asp-for="SuiteId" class="form-select" asp-items="ViewBag.SuiteId">
                                    <option value="">Selecione uma suíte</option>
                                </select>
                                <span asp-validation-for="SuiteId" class="text-danger"></span>
                            </div>
                            
                            <div class="col-md-6 mb-3">
                                <label asp-for="HospedeId" class="form-label">
                                    <i class="fas fa-user me-2"></i>Hóspede
                                </label>
                                <select asp-for="HospedeId" class="form-select" asp-items="ViewBag.HospedeId">
                                    <option value="">Selecione um hóspede</option>
                                </select>
                                <span asp-validation-for="HospedeId" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="DataEntrada" class="form-label">
                                    <i class="fas fa-calendar-plus me-2"></i>Data de Entrada
                                </label>
                                <input asp-for="DataEntrada" class="form-control" type="date" />
                                <span asp-validation-for="DataEntrada" class="text-danger"></span>
                            </div>
                            
                            <div class="col-md-6 mb-3">
                                <label asp-for="DataSaida" class="form-label">
                                    <i class="fas fa-calendar-minus me-2"></i>Data de Saída
                                </label>
                                <input asp-for="DataSaida" class="form-control" type="date" />
                                <span asp-validation-for="DataSaida" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Origem" class="form-label">
                                    <i class="fas fa-map-marker-alt me-2"></i>Origem da Reserva
                                </label>
                                <select asp-for="Origem" class="form-select">
                                    <option value="">Selecione a origem</option>
                                    <option value="@PensionatoApp.Models.OrigemReserva.Site">Site</option>
                                    <option value="@PensionatoApp.Models.OrigemReserva.Telefone">Telefone</option>
                                    <option value="@PensionatoApp.Models.OrigemReserva.Presencial">Presencial</option>
                                </select>
                                <span asp-validation-for="Origem" class="text-danger"></span>
                            </div>
                            
                            <div class="col-md-6 mb-3">
                                <label asp-for="Status" class="form-label">
                                    <i class="fas fa-flag me-2"></i>Status
                                </label>
                                <select asp-for="Status" class="form-select">
                                    <option value="@PensionatoApp.Models.StatusReserva.Ativa">Ativa</option>
                                    <option value="@PensionatoApp.Models.StatusReserva.Finalizada">Finalizada</option>
                                    <option value="@PensionatoApp.Models.StatusReserva.Cancelada">Cancelada</option>
                                </select>
                                <span asp-validation-for="Status" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Observacoes" class="form-label">
                                <i class="fas fa-sticky-note me-2"></i>Observações
                            </label>
                            <textarea asp-for="Observacoes" class="form-control" rows="3" placeholder="Observações adicionais sobre a reserva..."></textarea>
                            <span asp-validation-for="Observacoes" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Valores e Serviços -->
            <div class="col-lg-4">
                <!-- Serviços Adicionais -->
                <div class="card mb-4">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-cogs me-2"></i>
                            Serviços Adicionais
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" asp-for="TemArCondicionado" id="temArCondicionado">
                            <label class="form-check-label" for="temArCondicionado">
                                <i class="fas fa-snowflake text-info me-2"></i>
                                Ar Condicionado
                            </label>
                        </div>
                        
                        <div class="mb-3" id="precoArCondicionadoDiv">
                            <label asp-for="PrecoArCondicionado" class="form-label">Preço do Ar Condicionado</label>
                            <div class="input-group">
                                <span class="input-group-text">R$</span>
                                <input asp-for="PrecoArCondicionado" class="form-control" type="number" step="0.01" />
                            </div>
                            <span asp-validation-for="PrecoArCondicionado" class="text-danger"></span>
                        </div>

                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" asp-for="TemGaragem" id="temGaragem">
                            <label class="form-check-label" for="temGaragem">
                                <i class="fas fa-car text-warning me-2"></i>
                                Garagem
                            </label>
                        </div>
                        
                        <div class="mb-3" id="precoGaragemDiv">
                            <label asp-for="PrecoGaragem" class="form-label">Preço da Garagem</label>
                            <div class="input-group">
                                <span class="input-group-text">R$</span>
                                <input asp-for="PrecoGaragem" class="form-control" type="number" step="0.01" />
                            </div>
                            <span asp-validation-for="PrecoGaragem" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <!-- Valores Financeiros -->
                <div class="card mb-4">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-dollar-sign me-2"></i>
                            Valores Financeiros
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="ValorMensalTotal" class="form-label">Valor Mensal Total</label>
                            <div class="input-group">
                                <span class="input-group-text">R$</span>
                                <input asp-for="ValorMensalTotal" class="form-control" type="number" step="0.01" />
                            </div>
                            <span asp-validation-for="ValorMensalTotal" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ValorCaucao" class="form-label">Valor da Caução</label>
                            <div class="input-group">
                                <span class="input-group-text">R$</span>
                                <input asp-for="ValorCaucao" class="form-control" type="number" step="0.01" />
                            </div>
                            <span asp-validation-for="ValorCaucao" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ValorAdiantado" class="form-label">Valor Adiantado</label>
                            <div class="input-group">
                                <span class="input-group-text">R$</span>
                                <input asp-for="ValorAdiantado" class="form-control" type="number" step="0.01" />
                            </div>
                            <span asp-validation-for="ValorAdiantado" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-footer bg-light">
                        <div class="d-flex justify-content-between">
                            <div>
                                <a asp-controller="Suites" asp-action="Index" class="btn btn-secondary">
                                    <i class="fas fa-times me-2"></i>Cancelar
                                </a>
                            </div>
                            <div>
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-save me-2"></i>Salvar Alterações
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        $(document).ready(function() {
            // Controle da visibilidade dos campos de preço
            function togglePrecoFields() {
                if ($('#temArCondicionado').is(':checked')) {
                    $('#precoArCondicionadoDiv').show();
                } else {
                    $('#precoArCondicionadoDiv').hide();
                    $('input[name="PrecoArCondicionado"]').val('0');
                }

                if ($('#temGaragem').is(':checked')) {
                    $('#precoGaragemDiv').show();
                } else {
                    $('#precoGaragemDiv').hide();
                    $('input[name="PrecoGaragem"]').val('0');
                }
            }

            // Inicializar visibilidade
            togglePrecoFields();

            // Event handlers
            $('#temArCondicionado, #temGaragem').change(togglePrecoFields);

            // Validação de datas
            $('input[name="DataEntrada"], input[name="DataSaida"]').change(function() {
                var dataEntrada = new Date($('input[name="DataEntrada"]').val());
                var dataSaida = new Date($('input[name="DataSaida"]').val());

                if (dataEntrada && dataSaida && dataEntrada >= dataSaida) {
                    alert('A data de saída deve ser posterior à data de entrada.');
                    $('input[name="DataSaida"]').val('');
                }
            });
        });
    </script>
}