@model PensionatoApp.Controllers.HomeController.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard Administrativo";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row">
    <div class="col-md-12">
        <h1 class="display-4 mb-4">
            <i class="fas fa-tachometer-alt text-primary"></i>
            Dashboard
        </h1>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-3">
        <a href="@Url.Action("Index", "Suites")" class="text-decoration-none">
            <div class="card border-primary h-100">
                <div class="card-body text-center d-flex flex-column justify-content-center">
                    <i class="fas fa-bed fa-2x text-primary mb-2"></i>
                    <h5 class="card-title">Total de Suítes</h5>
                    <h3 class="text-primary">@Model.TotalSuites</h3>
                </div>
            </div>
        </a>
    </div>
    
    <div class="col-md-3">
        <a href="@Url.Action("Index", "Suites")" class="text-decoration-none">
            <div class="card border-success h-100">
                <div class="card-body text-center d-flex flex-column justify-content-center">
                    <i class="fas fa-check-circle fa-2x text-success mb-2"></i>
                    <h5 class="card-title">Suítes Ocupadas</h5>
                    <h3 class="text-success">@Model.SuitesOcupadas</h3>
                </div>
            </div>
        </a>
    </div>
    
    <div class="col-md-3">
        <a href="@Url.Action("SuitesLivres", "Suites")" class="text-decoration-none">
            <div class="card border-info h-100">
                <div class="card-body text-center d-flex flex-column justify-content-center">
                    <i class="fas fa-door-open fa-2x text-info mb-2"></i>
                    <h5 class="card-title">Suítes Livres</h5>
                    <h3 class="text-info">@Model.SuitesLivres</h3>
                </div>
            </div>
        </a>
    </div>
    
    <div class="col-md-3">
        <a href="@Url.Action("Index", "Hospedes")" class="text-decoration-none">
            <div class="card border-warning h-100">
                <div class="card-body text-center d-flex flex-column justify-content-center">
                    <i class="fas fa-users fa-2x text-warning mb-2"></i>
                    <h5 class="card-title">Hóspedes Ativos</h5>
                    <h3 class="text-warning">@Model.TotalHospedes</h3>
                </div>
            </div>
        </a>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-3">
        <a href="@Url.Action("Index", "Reservas")" class="text-decoration-none">
            <div class="card border-secondary h-100">
                <div class="card-body text-center d-flex flex-column justify-content-center">
                    <i class="fas fa-calendar-check fa-2x text-secondary mb-2"></i>
                    <h5 class="card-title">Reservas Ativas</h5>
                    <h3 class="text-secondary">@Model.ReservasAtivas</h3>
                </div>
            </div>
        </a>
    </div>
    
    <div class="col-md-3">
        <a href="@Url.Action("Index", "Pagamentos")" class="text-decoration-none">
            <div class="card border-danger h-100">
                <div class="card-body text-center d-flex flex-column justify-content-center">
                    <i class="fas fa-money-check-alt fa-2x text-danger mb-2"></i>
                    <h5 class="card-title">Pagamentos</h5>
                    <h3 class="text-danger">@Model.PagamentosPendentes</h3>
                </div>
            </div>
        </a>
    </div>
    
    <div class="col-md-3">
        <a href="@Url.Action("Relatorio", "Pagamentos")" class="text-decoration-none">
            <div class="card border-success h-100">
                <div class="card-body text-center d-flex flex-column justify-content-center">
                    <i class="fas fa-money-bill-wave fa-2x text-success mb-2"></i>
                    <h5 class="card-title">Receita Mensal</h5>
                    <h3 class="text-success">@Model.ReceitaMensal.ToString("C", new System.Globalization.CultureInfo("pt-BR"))</h3>
                </div>
            </div>
        </a>
    </div>
    
    <div class="col-md-3">
        <a href="@Url.Action("Index", "Notificacoes")" class="text-decoration-none">
            <div class="card border-@(Model.NotificacoesPendentes > 0 ? "warning" : "info") h-100">
                <div class="card-body text-center d-flex flex-column justify-content-center">
                    <i class="fas fa-bell fa-2x text-@(Model.NotificacoesPendentes > 0 ? "warning" : "info") mb-2"></i>
                    <h5 class="card-title">Notificações</h5>
                    <h3 class="text-@(Model.NotificacoesPendentes > 0 ? "warning" : "info")">@Model.NotificacoesPendentes</h3>
                    @if (Model.NotificacoesPendentes > 0)
                    {
                        <small class="text-warning">Requer atenção</small>
                    }
                    else
                    {
                        <small class="text-info">Tudo em ordem</small>
                    }
                </div>
            </div>
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5><i class="fas fa-chart-pie"></i> Taxa de Ocupação</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Selecionar Data:</label>
                    <input type="date" id="dataSelecionada" class="form-control" value="@Model.DataSelecionada.ToString("yyyy-MM-dd")" />
                </div>
                
                <div id="ocupacaoContainer">
                    <div class="progress mb-3" style="height: 25px;">
                        <div id="progressBar" class="progress-bar" role="progressbar" style="width: @Model.TaxaOcupacaoData%; background-color: var(--cor-dourado);">
                            <span id="porcentagemTexto">@Model.TaxaOcupacaoData%</span>
                        </div>
                    </div>
                    <p id="ocupacaoTexto" class="text-muted">@Model.SuitesOcupadasData de @Model.TotalSuites suítes ocupadas em @Model.DataSelecionada.ToString("dd/MM/yyyy")</p>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5><i class="fas fa-tools"></i> Ações Rápidas</h5>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a href="@Url.Action("Create", "Reservas")" class="btn btn-primary">
                        <i class="fas fa-plus"></i> Nova Reserva
                    </a>
                    <a href="@Url.Action("Create", "Hospedes")" class="btn btn-info">
                        <i class="fas fa-user-plus"></i> Novo Hóspede
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const dataSelecionada = document.getElementById('dataSelecionada');
    const progressBar = document.getElementById('progressBar');
    const porcentagemTexto = document.getElementById('porcentagemTexto');
    const ocupacaoTexto = document.getElementById('ocupacaoTexto');
    
    dataSelecionada.addEventListener('change', function() {
        const dataEscolhida = this.value;
        
        if (dataEscolhida) {
            // Mostrar loading
            progressBar.style.width = '0%';
            porcentagemTexto.textContent = 'Carregando...';
            ocupacaoTexto.textContent = 'Carregando dados de ocupação...';
            
            // Fazer requisição AJAX
            fetch(`@Url.Action("ObterOcupacaoPorData", "Home")?data=${dataEscolhida}`)
                .then(response => response.json())
                .then(data => {
                    // Atualizar a interface
                    progressBar.style.width = data.taxaOcupacao + '%';
                    porcentagemTexto.textContent = data.taxaOcupacao + '%';
                    ocupacaoTexto.textContent = `${data.suitesOcupadas} de ${data.totalSuites} suítes ocupadas em ${data.data}`;
                })
                .catch(error => {
                    console.error('Erro ao buscar dados de ocupação:', error);
                    porcentagemTexto.textContent = 'Erro';
                    ocupacaoTexto.textContent = 'Erro ao carregar dados de ocupação';
                });
        }
    });
});
</script>