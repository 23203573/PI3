@model PensionatoApp.Models.Hospede

@{
    ViewData["Title"] = "Detalhes do Hóspede";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="text-primary mb-1">
                        <i class="fas fa-user me-2"></i>
                        Detalhes do Hóspede
                    </h2>
                    <p class="text-muted mb-0">Informações completas do hóspede</p>
                </div>
                <div>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning me-2">
                        <i class="fas fa-edit"></i> Editar
                    </a>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Voltar
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Informações Pessoais -->
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-user me-2"></i>Informações Pessoais</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-sm-4"><strong>Nome Completo:</strong></div>
                        <div class="col-sm-8">@Model.NomeCompleto</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4"><strong>Documento:</strong></div>
                        <div class="col-sm-8">
                            @if(Model.EhBrasileiro)
                            {
                                if (!string.IsNullOrEmpty(Model.CPF))
                                {
                                    <text>CPF: @Model.CPF</text>
                                }
                                if (!string.IsNullOrEmpty(Model.RG))
                                {
                                    if (!string.IsNullOrEmpty(Model.CPF)) { <br /> }
                                    <text>RG: @Model.RG</text>
                                }
                            }
                            else
                            {
                                <text>@Model.TipoDocumentoEstrangeiro: @Model.NumeroDocumentoEstrangeiro</text>
                            }
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4"><strong>Data Nascimento:</strong></div>
                        <div class="col-sm-8">@Model.DataNascimento.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4"><strong>Data Cadastro:</strong></div>
                        <div class="col-sm-8">@Model.DataCadastro.ToString("dd/MM/yyyy HH:mm")</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4"><strong>Status:</strong></div>
                        <div class="col-sm-8">
                            @if (Model.Ativo)
                            {
                                <span class="badge bg-success">Ativo</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inativo</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Informações de Contato -->
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="fas fa-phone me-2"></i>Informações de Contato</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-sm-4"><strong>Telefone:</strong></div>
                        <div class="col-sm-8">
                            <i class="fas fa-phone me-1"></i>@Model.Telefone
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4"><strong>Email:</strong></div>
                        <div class="col-sm-8">
                            <i class="fas fa-envelope me-1"></i>@Model.Email
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Endereco))
                    {
                        <div class="row mb-3">
                            <div class="col-sm-4"><strong>Endereço:</strong></div>
                            <div class="col-sm-8">@Model.Endereco</div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.ContatoEmergenciaNome))
                    {
                        <div class="row mb-3">
                            <div class="col-sm-4"><strong>Contato Emergência:</strong></div>
                            <div class="col-sm-8">
                                @Model.ContatoEmergenciaNome
                                @if (!string.IsNullOrEmpty(Model.ContatoEmergenciaTelefone))
                                {
                                    <br><small class="text-muted">@Model.ContatoEmergenciaTelefone</small>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Observacoes))
    {
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0"><i class="fas fa-sticky-note me-2"></i>Observações</h5>
                    </div>
                    <div class="card-body">
                        <p class="mb-0">@Model.Observacoes</p>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Histórico de Reservas -->
    @if (Model.Reservas != null && Model.Reservas.Any())
    {
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0"><i class="fas fa-history me-2"></i>Histórico de Reservas</h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Suíte</th>
                                        <th>Data Entrada</th>
                                        <th>Data Saída</th>
                                        <th>Status</th>
                                        <th>Valor Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var reserva in Model.Reservas.OrderByDescending(r => r.DataEntrada))
                                    {
                                        <tr>
                                            <td>
                                                <span class="badge bg-info">Suíte @(reserva.Suite?.Numero ?? 0)</span>
                                            </td>
                                            <td>@reserva.DataEntrada.ToString("dd/MM/yyyy")</td>
                                            <td>@reserva.DataSaida.ToString("dd/MM/yyyy")</td>
                                            <td>
                                                @{
                                                    var dataAtual = DateTime.Now.Date;
                                                    var isReservaAtiva = reserva.Status == PensionatoApp.Models.StatusReserva.Ativa && 
                                                                        reserva.DataEntrada.Date <= dataAtual && 
                                                                        reserva.DataSaida.Date >= dataAtual;
                                                }
                                                
                                                @if (isReservaAtiva)
                                                {
                                                    <span class="badge bg-success">Ativo</span>
                                                }
                                                else if (reserva.Status == PensionatoApp.Models.StatusReserva.Ativa && dataAtual < reserva.DataEntrada.Date)
                                                {
                                                    <span class="badge bg-warning">Agendado</span>
                                                }
                                                else if (reserva.Status == PensionatoApp.Models.StatusReserva.Ativa && dataAtual > reserva.DataSaida.Date)
                                                {
                                                    <span class="badge bg-secondary">Finalizado</span>
                                                }
                                                else if (reserva.Status == PensionatoApp.Models.StatusReserva.Finalizada)
                                                {
                                                    <span class="badge bg-secondary">Finalizado</span>
                                                }
                                                else if (reserva.Status == PensionatoApp.Models.StatusReserva.Cancelada)
                                                {
                                                    <span class="badge bg-danger">Cancelado</span>
                                                }
                                            </td>
                                            <td>@reserva.ValorMensalTotal.ToString("C", new System.Globalization.CultureInfo("pt-BR"))</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row mb-4">
            <div class="col-12">
                <div class="alert alert-info">
                    <i class="fas fa-info-circle me-2"></i>
                    Este hóspede ainda não possui histórico de reservas.
                </div>
            </div>
        </div>
    }
</div>