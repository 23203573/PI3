@model PensionatoApp.Models.Hospede

@{
    ViewData["Title"] = "Editar Hóspede";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="text-primary mb-1">
                        <i class="fas fa-edit me-2"></i>
                        Editar Hóspede
                    </h2>
                    <p class="text-muted mb-0">Atualize as informações do hóspede</p>
                </div>
                <div>
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-info me-2">
                        <i class="fas fa-eye"></i> Visualizar
                    </a>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Voltar
                    </a>
                </div>
            </div>
        </div>
    </div>

    <form asp-action="Edit" method="post">
        <input asp-for="Id" type="hidden" />
        <input asp-for="DataCadastro" type="hidden" />
        
        <div class="row">
            <!-- Informações Pessoais -->
            <div class="col-md-6 mb-4">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="fas fa-user me-2"></i>Informações Pessoais</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="NomeCompleto" class="form-label">Nome Completo</label>
                            <input asp-for="NomeCompleto" class="form-control" placeholder="Nome completo do hóspede">
                            <span asp-validation-for="NomeCompleto" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Documento" class="form-label">Documento (CPF/RG)</label>
                                <input asp-for="Documento" class="form-control" placeholder="000.000.000-00">
                                <span asp-validation-for="Documento" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="DataNascimento" class="form-label">Data de Nascimento</label>
                                <input asp-for="DataNascimento" type="date" class="form-control">
                                <span asp-validation-for="DataNascimento" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Endereco" class="form-label">Endereço Completo</label>
                            <textarea asp-for="Endereco" class="form-control" rows="3" placeholder="Endereço completo do hóspede"></textarea>
                            <span asp-validation-for="Endereco" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <div class="form-check">
                                <input asp-for="Ativo" class="form-check-input" type="checkbox">
                                <label asp-for="Ativo" class="form-check-label">
                                    Hóspede Ativo
                                </label>
                            </div>
                            <small class="text-muted">Desmarque para inativar o hóspede no sistema</small>
                            <span asp-validation-for="Ativo" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Informações de Contato -->
            <div class="col-md-6 mb-4">
                <div class="card">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0"><i class="fas fa-phone me-2"></i>Informações de Contato</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Telefone" class="form-label">Telefone</label>
                                <input asp-for="Telefone" class="form-control" placeholder="(00) 00000-0000">
                                <span asp-validation-for="Telefone" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Email" class="form-label">Email</label>
                                <input asp-for="Email" type="email" class="form-control" placeholder="email@exemplo.com">
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                        </div>

                        <hr class="my-4">
                        <h6 class="text-muted mb-3"><i class="fas fa-exclamation-triangle me-1"></i>Contato de Emergência</h6>
                        
                        <div class="mb-3">
                            <label asp-for="ContatoEmergenciaNome" class="form-label">Nome do Contato</label>
                            <input asp-for="ContatoEmergenciaNome" class="form-control" placeholder="Nome completo do contato de emergência">
                            <span asp-validation-for="ContatoEmergenciaNome" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ContatoEmergenciaTelefone" class="form-label">Telefone do Contato</label>
                            <input asp-for="ContatoEmergenciaTelefone" class="form-control" placeholder="(00) 00000-0000">
                            <span asp-validation-for="ContatoEmergenciaTelefone" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Observações -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0"><i class="fas fa-sticky-note me-2"></i>Observações</h5>
                    </div>
                    <div class="card-body">
                        <textarea asp-for="Observacoes" class="form-control" rows="4" placeholder="Observações gerais sobre o hóspede (opcional)"></textarea>
                        <span asp-validation-for="Observacoes" class="text-danger"></span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Botões de Ação -->
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-body text-center">
                        <button type="submit" class="btn btn-success btn-lg me-3">
                            <i class="fas fa-save"></i> Salvar Alterações
                        </button>
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-info me-3">
                            <i class="fas fa-eye"></i> Visualizar
                        </a>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="fas fa-times"></i> Cancelar
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        $(document).ready(function() {
            // Formatação de telefone
            $('input[name="Telefone"], input[name="ContatoEmergenciaTelefone"]').on('input', function() {
                var value = this.value.replace(/\D/g, '');
                if (value.length <= 11) {
                    if (value.length <= 10) {
                        // (XX) XXXX-XXXX
                        value = value.replace(/(\d{2})(\d{4})(\d{0,4})/, '($1) $2-$3');
                    } else {
                        // (XX) XXXXX-XXXX
                        value = value.replace(/(\d{2})(\d{5})(\d{0,4})/, '($1) $2-$3');
                    }
                }
                this.value = value;
            });

            // Formatação de CPF
            $('input[name="Documento"]').on('input', function() {
                var value = this.value.replace(/\D/g, '');
                if (value.length <= 11) {
                    // Formato CPF: XXX.XXX.XXX-XX
                    value = value.replace(/(\d{3})(\d{3})(\d{3})(\d{0,2})/, '$1.$2.$3-$4');
                }
                this.value = value;
            });

            // Validação de email em tempo real
            $('input[type="email"]').on('blur', function() {
                var email = this.value;
                var emailRegex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
                
                if (email && !emailRegex.test(email)) {
                    $(this).addClass('is-invalid');
                    if ($(this).next('.invalid-feedback').length === 0) {
                        $(this).after('<div class="invalid-feedback">Email inválido</div>');
                    }
                } else {
                    $(this).removeClass('is-invalid');
                    $(this).next('.invalid-feedback').remove();
                }
            });

            // Confirmação antes de salvar
            $('form').on('submit', function(e) {
                if (!confirm('Confirma as alterações no cadastro do hóspede?')) {
                    e.preventDefault();
                }
            });
        });
    </script>
}