@model PensionatoApp.Models.Hospede
@{
    ViewData["Title"] = "Novo Hóspede";
}

<div class="row">
    <div class="col-md-8">
        <h2>
            <i class="fas fa-user-plus text-success"></i>
            Cadastrar Novo Hóspede
        </h2>
        <hr />
        
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="row">
                <div class="col-md-12">
                    <div class="mb-3">
                        <label asp-for="NomeCompleto" class="form-label">Nome Completo *</label>
                        <input asp-for="NomeCompleto" class="form-control" placeholder="Digite o nome completo" />
                        <span asp-validation-for="NomeCompleto" class="text-danger"></span>
                    </div>
                </div>
            </div>
            
            <div class="row">
                <div class="col-md-12">
                    <div class="mb-3">
                        <div class="form-check">
                            <input asp-for="EhBrasileiro" class="form-check-input" type="checkbox" id="ehBrasileiro" checked>
                            <label class="form-check-label" for="ehBrasileiro">
                                Sou brasileiro
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="naoSouBrasileiro">
                            <label class="form-check-label" for="naoSouBrasileiro">
                                Não sou brasileiro
                            </label>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Documentos brasileiros -->
            <div class="row" id="documentosBrasileiros">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="RG" class="form-label">RG *</label>
                        <input asp-for="RG" class="form-control" placeholder="00.000.000-0" required />
                        <span asp-validation-for="RG" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="CPF" class="form-label">CPF *</label>
                        <input asp-for="CPF" class="form-control" placeholder="000.000.000-00" required />
                        <span asp-validation-for="CPF" class="text-danger"></span>
                    </div>
                </div>
            </div>
            
            <!-- Documentos estrangeiros -->
            <div class="row" id="documentosEstrangeiros" style="display: none;">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="TipoDocumentoEstrangeiro" class="form-label">Tipo do Documento *</label>
                        <select asp-for="TipoDocumentoEstrangeiro" class="form-control">
                            <option value="">Selecione...</option>
                            <option value="Passaporte">Passaporte</option>
                            <option value="Carteira de Identidade">Carteira de Identidade</option>
                            <option value="RNE">RNE (Registro Nacional de Estrangeiro)</option>
                            <option value="Carteira de Motorista">Carteira de Motorista</option>
                            <option value="Outro">Outro</option>
                        </select>
                        <span asp-validation-for="TipoDocumentoEstrangeiro" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="NumeroDocumentoEstrangeiro" class="form-label">Número do Documento *</label>
                        <input asp-for="NumeroDocumentoEstrangeiro" class="form-control" placeholder="Número do documento" />
                        <span asp-validation-for="NumeroDocumentoEstrangeiro" class="text-danger"></span>
                    </div>
                </div>
            </div>
            
            <div class="row">
                <div class="col-md-4">
                    <div class="mb-3">
                        <label asp-for="DataNascimento" class="form-label">Data de Nascimento *</label>
                        <input asp-for="DataNascimento" type="text" class="form-control data-input" placeholder="dd/mm/aaaa" />
                        <span asp-validation-for="DataNascimento" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="mb-3">
                        <label asp-for="Telefone" class="form-label">Telefone *</label>
                        <input asp-for="Telefone" class="form-control" placeholder="(11) 99999-9999" />
                        <span asp-validation-for="Telefone" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">E-mail *</label>
                        <input asp-for="Email" type="email" class="form-control" placeholder="email@exemplo.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                </div>
            </div>
            
            <div class="mb-3">
                <label asp-for="Endereco" class="form-label">Endereço *</label>
                <input asp-for="Endereco" class="form-control" placeholder="Rua, número, bairro, cidade" />
                <span asp-validation-for="Endereco" class="text-danger"></span>
            </div>
            
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="ContatoEmergenciaNome" class="form-label">Contato de Emergência - Nome *</label>
                        <input asp-for="ContatoEmergenciaNome" class="form-control" placeholder="Nome do contato" />
                        <span asp-validation-for="ContatoEmergenciaNome" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="ContatoEmergenciaTelefone" class="form-label">Contato de Emergência - Telefone *</label>
                        <input asp-for="ContatoEmergenciaTelefone" class="form-control" placeholder="(11) 99999-9999" />
                        <span asp-validation-for="ContatoEmergenciaTelefone" class="text-danger"></span>
                    </div>
                </div>
            </div>
            
            <div class="mb-3">
                <label asp-for="Observacoes" class="form-label">Observações</label>
                <textarea asp-for="Observacoes" class="form-control" rows="3" placeholder="Alergias, necessidades especiais, etc."></textarea>
                <span asp-validation-for="Observacoes" class="text-danger"></span>
            </div>
            
            <div class="row">
                <div class="col-md-12">
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-save"></i> Salvar Hóspede
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Voltar
                    </a>
                </div>
            </div>
        </form>
    </div>
    
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h5><i class="fas fa-info-circle"></i> Informações</h5>
            </div>
            <div class="card-body">
                <p><strong>Campos obrigatórios:</strong></p>
                <ul>
                    <li>Nome Completo</li>
                    <li><strong>Para brasileiros:</strong> RG e CPF</li>
                    <li><strong>Para estrangeiros:</strong> Tipo e número do documento</li>
                    <li>Data de Nascimento</li>
                    <li>Telefone</li>
                    <li>E-mail</li>
                    <li>Endereço</li>
                    <li>Contato de Emergência - Nome</li>
                    <li>Contato de Emergência - Telefone</li>
                </ul>
                
                <hr/>
                
                <p><strong>Dicas:</strong></p>
                <ul>
                    <li>Verifique se os dados estão corretos antes de salvar</li>
                    <li>O contato de emergência é recomendado para estudantes</li>
                    <li>Anote qualquer alergia ou necessidade especial</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        $(document).ready(function() {
            // Controle dos checkboxes de nacionalidade
            $('#ehBrasileiro').on('change', function() {
                if ($(this).is(':checked')) {
                    $('#naoSouBrasileiro').prop('checked', false);
                    $('#documentosBrasileiros').show();
                    $('#documentosEstrangeiros').hide();
                    
                    // Tornar campos brasileiros obrigatórios
                    $('#RG').attr('required', true);
                    $('#CPF').attr('required', true);
                    
                    // Remover obrigatoriedade dos campos estrangeiros
                    $('#TipoDocumentoEstrangeiro').attr('required', false);
                    $('#NumeroDocumentoEstrangeiro').attr('required', false);
                }
            });
            
            $('#naoSouBrasileiro').on('change', function() {
                if ($(this).is(':checked')) {
                    $('#ehBrasileiro').prop('checked', false);
                    $('#documentosBrasileiros').hide();
                    $('#documentosEstrangeiros').show();
                    
                    // Remover obrigatoriedade dos campos brasileiros
                    $('#RG').attr('required', false);
                    $('#CPF').attr('required', false);
                    
                    // Tornar campos estrangeiros obrigatórios
                    $('#TipoDocumentoEstrangeiro').attr('required', true);
                    $('#NumeroDocumentoEstrangeiro').attr('required', true);
                    
                    // Atualizar o valor do EhBrasileiro
                    $('#EhBrasileiro').val(false);
                } else {
                    // Se desmarcou "não sou brasileiro", marca automaticamente "sou brasileiro"
                    $('#ehBrasileiro').prop('checked', true).trigger('change');
                }
            });
            
            // Validação personalizada antes do submit
            $('form').on('submit', function(e) {
                var ehBrasileiro = $('#ehBrasileiro').is(':checked');
                var isValid = true;
                
                if (ehBrasileiro) {
                    // Validar campos brasileiros
                    if (!$('#RG').val().trim()) {
                        alert('RG é obrigatório para brasileiros');
                        isValid = false;
                    }
                    if (!$('#CPF').val().trim()) {
                        alert('CPF é obrigatório para brasileiros');
                        isValid = false;
                    }
                } else {
                    // Validar campos estrangeiros
                    if (!$('#TipoDocumentoEstrangeiro').val()) {
                        alert('Tipo do documento é obrigatório para estrangeiros');
                        isValid = false;
                    }
                    if (!$('#NumeroDocumentoEstrangeiro').val().trim()) {
                        alert('Número do documento é obrigatório para estrangeiros');
                        isValid = false;
                    }
                }
                
                if (!isValid) {
                    e.preventDefault();
                }
            });
        });
    </script>
}