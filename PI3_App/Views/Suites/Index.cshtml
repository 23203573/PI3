@model IEnumerable<PensionatoApp.Models.Suite>

@{
    ViewData["Title"] = "Gestão de Suítes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="text-primary">
            <i class="fas fa-bed me-2"></i>
            Gestão de Suítes
            <span class="badge bg-primary ms-2">@ViewBag.TotalSuites suítes</span>
        </h2>
        <p class="text-muted mb-0">
            <span class="badge bg-secondary me-2">@ViewBag.SuitesLivres livres</span>
            <span class="badge bg-warning">@ViewBag.SuitesOcupadas ocupadas</span>
        </p>
    </div>
    <div>
        <a asp-action="Create" class="btn btn-success me-2">
            <i class="fas fa-plus"></i> Nova Suíte
        </a>
        <a asp-action="Ocupacao" class="btn btn-outline-info">
            <i class="fas fa-calendar-alt"></i> Ver Ocupação
        </a>
    </div>
</div>

@if (Model.Any())
{
    <div class="card">
        <div class="card-header bg-light">
            <h5 class="mb-0">
                <i class="fas fa-table me-2"></i>
                Todas as Suítes Cadastradas
            </h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th scope="col" class="text-center" style="width: 8%;">
                                <i class="fas fa-door-open me-1"></i>Suíte
                            </th>
                            <th scope="col" style="width: 15%;">
                                <i class="fas fa-dollar-sign me-1"></i>Preço Base
                            </th>
                            <th scope="col" style="width: 12%;">
                                <i class="fas fa-bed me-1"></i>Cama
                            </th>
                            <th scope="col" class="text-center" style="width: 15%;">
                                <i class="fas fa-cogs me-1"></i>Serviços
                            </th>
                            <th scope="col" class="text-center" style="width: 12%;">
                                <i class="fas fa-info-circle me-1"></i>Status
                            </th>
                            <th scope="col" style="width: 20%;">
                                <i class="fas fa-user me-1"></i>Ocupação Atual
                            </th>
                            <th scope="col" class="text-center" style="width: 18%;">
                                <i class="fas fa-tools me-1"></i>Ações
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var suite in Model.OrderBy(s => s.Numero))
                        {
                            var hoje = DateTime.Today;
                            var reservaAtiva = suite.Reservas?.FirstOrDefault(r => 
                                r.Status == PensionatoApp.Models.StatusReserva.Ativa &&
                                r.DataEntrada <= hoje && 
                                r.DataSaida > hoje);
                            var isOcupada = reservaAtiva != null;
                            
                            <tr class="@(isOcupada ? "table-warning" : "table-success")">
                                <td class="text-center">
                                    <span class="badge bg-@(isOcupada ? "warning" : "success") fs-6 p-2">
                                        @suite.Numero
                                    </span>
                                </td>
                                
                                <td>
                                    <div class="fw-semibold">@suite.PrecoMensal.ToString("C", new System.Globalization.CultureInfo("pt-BR"))</div>
                                    @if (suite.ArCondicionado && suite.PrecoArCondicionado > 0)
                                    {
                                        <div class="small text-muted">
                                            + @suite.PrecoArCondicionado.ToString("C", new System.Globalization.CultureInfo("pt-BR")) (A/C)
                                        </div>
                                    }
                                </td>
                                
                                <td>
                                    <span class="badge bg-info">@suite.TipoCama</span>
                                </td>
                                
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-1 flex-wrap">
                                        @if (suite.ArCondicionado)
                                        {
                                            <span class="badge bg-info" title="Ar Condicionado">
                                                <i class="fas fa-snowflake"></i>
                                            </span>
                                        }
                                        @if (suite.WiFi)
                                        {
                                            <span class="badge bg-primary" title="WiFi">
                                                <i class="fas fa-wifi"></i>
                                            </span>
                                        }
                                        @if (suite.Geladeira)
                                        {
                                            <span class="badge bg-success" title="Geladeira">
                                                <i class="fas fa-snowman"></i>
                                            </span>
                                        }
                                        @if (suite.MesaEstudos)
                                        {
                                            <span class="badge bg-warning" title="Mesa de Estudos">
                                                <i class="fas fa-desk"></i>
                                            </span>
                                        }
                                    </div>
                                </td>
                                
                                <td class="text-center">
                                    @switch (suite.Status)
                                    {
                                        case PensionatoApp.Models.StatusSuite.Livre:
                                            <span class="badge bg-secondary">Livre</span>
                                            break;
                                        case PensionatoApp.Models.StatusSuite.Ocupada:
                                            <span class="badge bg-warning">Ocupada</span>
                                            break;
                                        case PensionatoApp.Models.StatusSuite.EmManutencao:
                                            <span class="badge bg-danger">Em Manutenção</span>
                                            break;
                                        case PensionatoApp.Models.StatusSuite.EmLimpeza:
                                            <span class="badge bg-info">Em Limpeza</span>
                                            break;
                                    }
                                </td>
                                
                                <td>
                                    @if (isOcupada && reservaAtiva != null)
                                    {
                                        <div class="fw-semibold text-dark">@(reservaAtiva.Hospede?.NomeCompleto ?? "N/A")</div>
                                        <div class="small text-muted">
                                            <i class="fas fa-calendar me-1"></i>
                                            @reservaAtiva.DataEntrada.ToString("dd/MM/yyyy") - @reservaAtiva.DataSaida.ToString("dd/MM/yyyy")
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">
                                            <i class="fas fa-check-circle me-1"></i>Livre
                                        </span>
                                    }
                                </td>
                                
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Details" asp-route-id="@suite.Id" class="btn btn-outline-info btn-sm" title="Detalhes">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@suite.Id" class="btn btn-outline-warning btn-sm" title="Editar">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        @if (!isOcupada)
                                        {
                                            <form asp-action="Delete" asp-route-id="@suite.Id" method="post" style="display:inline;" 
                                                  onsubmit="return confirm('Tem certeza que deseja excluir a suíte @suite.Numero?');">
                                                <button type="submit" class="btn btn-outline-danger btn-sm" title="Excluir">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-outline-secondary btn-sm" title="Não é possível excluir (ocupada)" disabled>
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-light text-muted">
            <div class="row">
                <div class="col-md-6">
                    <small>
                        <i class="fas fa-info-circle me-1"></i>
                        <span class="badge bg-success me-1">Livre</span> Suíte disponível |
                        <span class="badge bg-warning ms-1">Ocupada</span> Com reserva ativa
                    </small>
                </div>
                <div class="col-md-6 text-md-end">
                    <small>
                        <i class="fas fa-calendar me-1"></i>
                        Atualizado em: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")
                    </small>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-info text-center py-5">
        <h4><i class="fas fa-info-circle me-2"></i>Nenhuma suíte cadastrada</h4>
        <p class="mb-3">Cadastre sua primeira suíte para começar a gerenciar o pensionato.</p>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Cadastrar Primeira Suíte
        </a>
    </div>
}