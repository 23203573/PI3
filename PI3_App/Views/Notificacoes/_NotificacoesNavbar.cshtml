@model IEnumerable<PensionatoApp.Models.Notificacao>

@if (Model.Any())
{
    <li class="nav-item dropdown">
        <a class="nav-link dropdown-toggle text-white position-relative" href="#" role="button" data-bs-toggle="dropdown">
            <i class="fas fa-bell"></i>
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                @Model.Count()
                <span class="visually-hidden">notificações não lidas</span>
            </span>
        </a>
        <ul class="dropdown-menu dropdown-menu-end" style="min-width: 350px; max-height: 400px; overflow-y: auto;">
            <li>
                <h6 class="dropdown-header">
                    <i class="fas fa-bell me-1"></i>
                    Notificações (@Model.Count() não lidas)
                </h6>
            </li>
            <li><hr class="dropdown-divider"></li>
            
            @foreach (var notificacao in Model.Take(5))
            {
                var corIcone = "";
                var icone = "";
                
                switch (notificacao.Tipo)
                {
                    case PensionatoApp.Models.TipoNotificacao.CheckOut:
                        corIcone = "text-danger";
                        icone = "fas fa-sign-out-alt";
                        break;
                    case PensionatoApp.Models.TipoNotificacao.VencimentoAluguel:
                        corIcone = "text-warning";
                        icone = "fas fa-clock";
                        break;
                    case PensionatoApp.Models.TipoNotificacao.PagamentoPendente:
                        corIcone = "text-danger";
                        icone = "fas fa-dollar-sign";
                        break;
                    case PensionatoApp.Models.TipoNotificacao.Manutencao:
                        corIcone = "text-info";
                        icone = "fas fa-tools";
                        break;
                    default:
                        corIcone = "text-primary";
                        icone = "fas fa-info-circle";
                        break;
                }
                
                <li>
                    <a class="dropdown-item py-2" href="@Url.Action("Index", "Notificacoes")">
                        <div class="d-flex">
                            <div class="flex-shrink-0">
                                <i class="@icone @corIcone"></i>
                            </div>
                            <div class="flex-grow-1 ms-2">
                                <div class="fw-bold small">@notificacao.Titulo</div>
                                <div class="text-muted small" style="font-size: 0.8rem;">
                                    @(notificacao.Mensagem.Length > 60 ? notificacao.Mensagem.Substring(0, 60) + "..." : notificacao.Mensagem)
                                </div>
                                <div class="text-muted" style="font-size: 0.7rem;">
                                    <i class="fas fa-clock me-1"></i>
                                    @notificacao.DataCriacao.ToString("dd/MM HH:mm")
                                </div>
                            </div>
                        </div>
                    </a>
                </li>
                @if (!Model.Last().Equals(notificacao))
                {
                    <li><hr class="dropdown-divider"></li>
                }
            }
            
            @if (Model.Count() > 5)
            {
                <li><hr class="dropdown-divider"></li>
                <li>
                    <div class="text-center small text-muted p-2">
                        E mais @(Model.Count() - 5) notificação(ões)...
                    </div>
                </li>
            }
            
            <li><hr class="dropdown-divider"></li>
            <li>
                <a class="dropdown-item text-center" href="@Url.Action("Index", "Notificacoes")">
                    <i class="fas fa-eye me-1"></i>
                    Ver Todas as Notificações
                </a>
            </li>
        </ul>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link text-white" href="@Url.Action("Index", "Notificacoes")" title="Notificações">
            <i class="fas fa-bell"></i>
        </a>
    </li>
}